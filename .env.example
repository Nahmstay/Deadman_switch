# Solana RPC endpoint (mainnet-beta / devnet / localnet)
# Use a Helius RPC URL for lower latency when the webhook server is deployed:
# https://rpc.helius.xyz/?api-key=YOUR_API_KEY
RPC_URL=https://api.devnet.solana.com

# The switch owner's public key (base58)
OWNER_PUBKEY=

# Discord webhook URL for reminder notifications
DISCORD_WEBHOOK=

# ── Helius Webhook Server (webhook-server.ts) ─────────────────────────────────
# See README → "Helius Event-Driven Monitoring" for full setup instructions.

# Port the webhook server listens on (default: 3000)
WEBHOOK_PORT=3000

# Authorization token — paste this same value into the Helius dashboard
# under Webhook → Authorization Header. Prevents unauthorized calls.
HELIUS_AUTH_HEADER=
